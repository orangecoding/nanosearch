# Comma-separated list of directories to index
SEARCH_DIRS=/path/to/your/documents

# SQLite database file path
DB_PATH=./db/nanosearch.db

# OCR backend: js (Tesseract.js, default) | cli (Tesseract CLI, faster, used in Docker)
OCR_BACKEND=js

# Server port
PORT=3000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# File extensions to index
# Add or remove any extension to control exactly what gets indexed.
# Images require OCR; everything else is read as plain text.
EXTENSIONS=.pdf,.docx,.txt,.md,.rtf,.yaml,.yml,.log,.tiff,.tif,.csv
